---
const {
  label,
  name,
  required = false,
  value,
  min,
  max,
  class: className,
  editable = true,
  "data-prop": customDataProp = "label",
  _component,
  ...htmlAttributes
} = Astro.props;

const labelDataAttributes =
  editable && customDataProp
    ? {
        "data-editable": "text",
        "data-prop": customDataProp,
      }
    : {};

const fieldId = htmlAttributes.id || `date-${crypto.randomUUID()}`;
---

<div class:list={["date", className]}>
  {
    label && (
      <label for={fieldId} class="label">
        <span {...labelDataAttributes}>{label}</span>
        {required && (
          <span class="date-required" aria-label="required">
            *
          </span>
        )}
      </label>
    )
  }
  <input
    type="date"
    name={name}
    id={fieldId}
    required={required}
    aria-required={required}
    value={value}
    min={min}
    max={max}
    class="field"
    {...htmlAttributes}
  />
</div>

<style is:global>
  @layer components {
    .date {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
      margin: 0;
      margin-bottom: var(--spacing-md);
      width: 100%;

      .date-required {
        color: red;
        margin-inline-end: var(--spacing-em-xs);
      }
    }
  }
</style>
