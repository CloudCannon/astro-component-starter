---
const {
  label,
  name,
  required = false,
  accept,
  multiple = false,
  class: className,
  editable = true,
  _component,
  "data-prop": customDataProp = "label",
  ...htmlAttributes
} = Astro.props;

const labelDataAttributes =
  editable && customDataProp
    ? {
        "data-editable": "text",
        "data-prop": customDataProp,
      }
    : {};

const fieldId = htmlAttributes.id || `file-upload-${crypto.randomUUID()}`;
---

<div class:list={["file-upload", className]}>
  {
    label && (
      <label for={fieldId} class="label">
        <span {...labelDataAttributes}>{label}</span>
        {required && (
          <span class="file-upload-required" aria-label="required">
            *
          </span>
        )}
      </label>
    )
  }
  <input
    type="file"
    name={name}
    id={fieldId}
    required={required}
    aria-required={required}
    accept={accept}
    multiple={multiple}
    class="field"
    {...htmlAttributes}
  />
</div>

<style is:global>
  @layer components {
    .file-upload {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
      margin: 0;
      margin-bottom: var(--spacing-md);
      width: 100%;

      .file-upload-required {
        color: red;
        margin-inline-end: var(--spacing-em-xs);
      }
    }
  }
</style>
