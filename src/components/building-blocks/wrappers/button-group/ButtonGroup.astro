---
import { slugifyLabel } from "@components/utils/slugify";
import Button from "@core-elements/button/Button.astro";

const {
  direction = "row",
  alignX = "start",
  buttons,
  "data-children-prop": childrenDataProp,
  editable = false,
  class: className,
  label,
  _component,
  ...htmlAttributes
} = Astro.props;

const effectiveChildrenProp = childrenDataProp ?? (editable ? "buttons" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const alignMap = {
  start: "align-start",
  center: "align-center",
  end: "align-end",
} as const;

const alignClass = alignMap[alignX as keyof typeof alignMap] ?? "align-start";

const normalizedButtons: Array<Record<string, unknown>> = Array.isArray(buttons) ? buttons : [];
const hasButtons = normalizedButtons.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasButtons && !hasSlotContent) return;
---

<div
  class:list={["button-group", direction === "column" ? "column" : "row", alignClass, className]}
  {...htmlAttributes}
>
  <div class="button-group__items" {...arrayDataAttributes}>
    <slot>
      {
        normalizedButtons.map((button) => (
          <Button
            data-editable={effectiveChildrenProp ? "array-item" : undefined}
            data-id="building-blocks/core-elements/button"
            editable={!!effectiveChildrenProp}
            {...button}
          />
        ))
      }
    </slot>
  </div>
</div>

<style is:global>
  @layer components {
    .button-group {
      container-type: inline-size;
      margin-top: var(--spacing-lg);
      position: relative;
      width: 100%;

      > .button-group__items {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-sm);
        justify-content: flex-start;
        width: 100%;
      }

      &.column {
        > .button-group__items {
          flex-direction: column;
        }

        &.align-start {
          > .button-group__items {
            align-items: flex-start;
          }
        }

        &.align-end {
          > .button-group__items {
            align-items: flex-end;
          }
        }
      }

      &.row {
        > .button-group__items {
          flex-direction: row;
        }

        &.align-center {
          > .button-group__items {
            justify-content: center;
          }
        }

        &.align-end {
          > .button-group__items {
            justify-content: flex-end;
          }
        }
      }
    }
  }
</style>
