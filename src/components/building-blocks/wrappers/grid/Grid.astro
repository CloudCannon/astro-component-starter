---
import { slugifyLabel } from "@components/utils/slugify";
import GridItem from "./GridItem.astro";

const {
  layout = "center",
  minItemWidth = 200,
  maxItemWidth = 320,
  class: className,
  style: userStyle,
  items = [],
  label,
  gap = "md",
  editable = false,
  _component,
  "data-children-prop": childrenDataProp = "items",
  innerComponent = "building-blocks/wrappers/grid/grid-item",
  ...htmlAttributes
} = Astro.props;

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const gridStyles = [
  `--min-item-width: ${minItemWidth}px`,
  `--max-item-width: ${maxItemWidth}px`,
  `--grid-spacing: var(--spacing-${gap})`,
  userStyle,
]
  .filter(Boolean)
  .join("; ");

const arrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-component-key": "_component",
      "data-prop": childrenDataProp,
    }
  : {};

const hasItems = items?.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasItems && !hasSlotContent) return;
---

<div class:list={["grid", `layout-${layout}`, className]} style={gridStyles} {...htmlAttributes}>
  <div {...arrayDataAttributes} class="grid-inner">
    <slot>
      {
        items?.map((item: any) => (
          <GridItem
            data-editable="array-item"
            data-id={item._component}
            class:list={`layout-${layout}`}
            editable={editable}
            {...item}
          />
        ))
      }
    </slot>
  </div>
</div>

<style is:global>
  @layer components {
    .grid {
      margin-top: var(--spacing-lg);
      width: 100%;
    }

    .grid.layout-start > .grid-inner {
      align-items: stretch;
      display: grid;
      gap: var(--grid-spacing, var(--spacing-md));
      grid-template-columns: repeat(auto-fill, minmax(min(var(--min-item-width), 100%), 1fr));
      justify-content: start;
      width: 100%;
    }

    .grid.layout-center > .grid-inner {
      align-items: stretch;
      display: flex;
      flex-wrap: wrap;
      gap: var(--grid-spacing, var(--spacing-md));
      justify-content: center;
      width: 100%;
    }

    .grid.layout-center > .grid-inner > .grid-item {
      flex: 1 1 var(--min-item-width, 200px);
      max-width: var(--max-item-width, 320px);
      min-width: min(var(--min-item-width, 200px), 100%);
    }
  }
</style>
