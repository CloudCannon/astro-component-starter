---
import RenderBlock from "@components/utils/renderBlock.astro";

const {
  contentSections,
  editable = true,
  class: className,
  _component,
  "data-prop": customDataProp = "contentSections",
  ...htmlAttributes
} = Astro.props;

const arrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-id-key": "_component",
    }
  : {};
---

<div class:list={["grid-item", className]} {...htmlAttributes}>
  <div class="grid-item-content" {...arrayDataAttributes}>
    <slot>
      {
        contentSections && (
          <RenderBlock
            contentSections={contentSections}
            propName={customDataProp}
            editable={editable}
          />
        )
      }
    </slot>
  </div>
</div>

<style is:global>
  @layer components {
    .grid-item {
      container-type: inline-size;
      > .grid-item-content {
        height: 100%;
      }

      > .grid-item-content > *:only-child {
        height: 100%;
      }

      > .grid-item-content > *:first-child {
        margin-top: 0 !important;
      }
    }
  }
</style>
