---
import { slugifyLabel } from "@components/utils/slugify";
import MasonryItem from "./MasonryItem.astro";

type ItemProps = Record<string, unknown>;

const {
  columns = 3,
  gap = "md",
  label,
  items = [],
  class: className,
  useDefaultEditableBinding = false,
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const effectiveChildrenProp = childrenDataProp ?? (useDefaultEditableBinding ? "items" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp, "data-direction": "row" }
  : {};

const hasItems = items?.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasItems && !hasSlotContent) return;
---

<div
  class:list={["masonry", className]}
  {...htmlAttributes}
>
  <div
    {...arrayDataAttributes}
    class:list={["masonry-inner", `columns-${columns}`, `gap-${gap}`]}
  >
    <slot>
      {
        items?.map((item: ItemProps) => (
          <MasonryItem
            data-id="building-blocks/wrappers/masonry/masonry-item"
            data-editable="array-item"
            useDefaultEditableBinding={!!effectiveChildrenProp}
            {...item}
          />
        ))
      }
    </slot>
  </div>
</div>

<style>
  @layer components {
    .masonry {
      container-type: inline-size;
      margin-top: var(--spacing-lg);
      width: 100%;

      > .masonry-inner {
        &.columns-2 {
          columns: 2;
        }

        &.columns-3 {
          columns: 3;
        }

        &.columns-4 {
          columns: 4;
        }

        &.gap-xs {
          column-gap: var(--spacing-xs);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-xs);
          }
        }

        &.gap-sm {
          column-gap: var(--spacing-sm);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-sm);
          }
        }

        &.gap-md {
          column-gap: var(--spacing-md);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-md);
          }
        }

        &.gap-lg {
          column-gap: var(--spacing-lg);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-lg);
          }
        }

        &.gap-xl {
          column-gap: var(--spacing-xl);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-xl);
          }
        }

        &.gap-2xl {
          column-gap: var(--spacing-2xl);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-2xl);
          }
        }

        &.gap-3xl {
          column-gap: var(--spacing-3xl);

          > :global(.masonry-item) {
            margin-bottom: var(--spacing-3xl);
          }
        }

        > :global(.masonry-item) {
          min-width: 0;
        }

        > :global(.masonry-item:last-child) {
          margin-bottom: 0;
        }

        @container (max-width: 700px) {
          &.columns-3,
          &.columns-4 {
            columns: 2;
          }

          &.gap-lg {
            column-gap: var(--spacing-md);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-md);
            }
          }

          &.gap-xl {
            column-gap: var(--spacing-md);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-md);
            }
          }

          &.gap-2xl {
            column-gap: var(--spacing-lg);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-lg);
            }
          }

          &.gap-3xl {
            column-gap: var(--spacing-xl);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-xl);
            }
          }
        }

        @container (max-width: 450px) {
          &.columns-2,
          &.columns-3,
          &.columns-4 {
            columns: 1;
          }

          &.gap-sm {
            column-gap: var(--spacing-xs);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-xs);
            }
          }

          &.gap-md {
            column-gap: var(--spacing-sm);

            > :global(.masonry-item) {
              margin-bottom: var(--spacing-sm);
            }
          }
        }
      }
    }
  }
</style>
